@model RentACar.Models.User

@{
    ViewData["Title"] = "Create User";
}

<div class="form-page">
    <div class="form-card">
        <h1>Create User</h1>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="validation-text"></div>

            <div class="form-group">
                <label asp-for="Username"></label>
                <input asp-for="Username" class="form-input" />
                <span asp-validation-for="Username" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="form-input" />
                <span asp-validation-for="Password" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName" class="form-input" />
                <span asp-validation-for="FirstName" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName"></label>
                <input asp-for="LastName" class="form-input" />
                <span asp-validation-for="LastName" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="EGN"></label>
                <input asp-for="EGN" class="form-input" />
                <span asp-validation-for="EGN" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" />
                <span asp-validation-for="Email" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="PhoneNumber"></label>
                <input asp-for="PhoneNumber" class="form-input" />
                <span asp-validation-for="PhoneNumber" class="validation-text"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-main">Create</button>
                <a asp-action="Index" class="btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}