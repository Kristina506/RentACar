@model IEnumerable<RentACar.Models.User>

@{
    ViewData["Title"] = "Users";
}

<div class="users-page">
    <div class="users-header">
        <h1>Users</h1>
        <a asp-action="Create" class="btn-main">+ Add User</a>
    </div>

    <div class="users-table-wrapper">
        <table class="users-table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>First Name</th>
                    <th>Last Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>EGN</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>@user.FirstName</td>
                        <td>@user.LastName</td>
                        <td>@user.Email</td>
                        <td>@user.PhoneNumber</td>
                        <td>@user.EGN</td>
                        <td class="action-links">
                            <a asp-action="Details" asp-route-id="@user.Id" class="btn-small details-btn">Details</a>
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn-small edit-btn">Edit</a>
                            <a asp-action="Delete" asp-route-id="@user.Id" class="btn-small delete-btn">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>