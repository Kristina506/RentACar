@using Microsoft.AspNetCore.Http
@model List<RentACar.Models.Car>

@{
    ViewData["Title"] = "Cars";
    var role = Context.Session.GetString("Role");
}

<h1>Cars</h1>

@if (role == "Admin")
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Car</a>
    </p>
}

@if (Model == null || !Model.Any())
{
    <p>No cars available.</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Brand</th>
                <th>Model</th>
                <th>Year</th>
                <th>Seats</th>
                <th>Price Per Day</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var car in Model)
            {
                <tr>
                    <td>@car.Brand</td>
                    <td>@car.Model</td>
                    <td>@car.Year</td>
                    <td>@car.Seats</td>
                    <td>@car.PricePerDay.ToString("F2")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@car.Id">Details</a>

                        @if (role == "Admin")
                        {
                            <text> | </text>
                            <a asp-action="Edit" asp-route-id="@car.Id">Edit</a>
                            <text> | </text>
                            <a asp-action="Delete" asp-route-id="@car.Id">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}