@model RentACar.Models.Car

@{
    ViewData["Title"] = "Delete Car";
}

<h1>Delete Car</h1>

<h3>Are you sure you want to delete this car?</h3>

<div class="card p-3">
    <p><strong>Brand:</strong> @Model.Brand</p>
    <p><strong>Model:</strong> @Model.Model</p>
    <p><strong>Year:</strong> @Model.Year</p>
    <p><strong>Seats:</strong> @Model.Seats</p>
    <p><strong>Description:</strong> @Model.Description</p>
    <p><strong>Price Per Day:</strong> @Model.PricePerDay.ToString("F2")</p>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>